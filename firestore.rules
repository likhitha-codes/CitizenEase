rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net catch-all block
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validating security tokens and inputs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Zero-Trust ABAC validation helper for Citizen History document insertions
    function isValidHistoryItem(data) {
      return data.keys().hasAll(['title', 'category', 'simplifiedEnglish', 'createdAt', 'userEmail'])
        && data.keys().size() <= 11
        && data.title is string && data.title.size() <= 500
        && data.category is string && data.category.size() <= 150
        && data.simplifiedEnglish is string && data.simplifiedEnglish.size() <= 100000
        && data.userEmail is string && data.userEmail == request.auth.token.email
        && data.get('userId', request.auth.uid) == request.auth.uid;
    }

    // Citizen history entries collection configuration
    match /citizen_history/{historyId} {
      allow create: if isSignedIn() 
        && isValidId(historyId)
        && isValidHistoryItem(request.resource.data)
        && (request.resource.data.createdAt == request.time || request.resource.data.createdAt is string);
      
      allow read, delete: if isSignedIn()
        && (resource.data.get('userEmail', '') == request.auth.token.email
            || resource.data.get('userId', '') == request.auth.uid);
        
      allow update: if false; // Documents are immutable for auditing and tamper protection
    }

    // Citizen Profiles
    match /users/{userId} {
      allow read, create: if true;
      allow update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Shares Snapshots
    match /shares/{shareId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
  }
}
